---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FeatureCard from '../components/FeatureCard.astro';
import InfoCallout from '../components/InfoCallout.astro';

const features = [
  {
    icon: '🏪',
    title: 'Player-Run Economy',
    description: 'The admin shop is a fallback. Real goods — elytras, shulkers, high-tier tools — come from players.',
  },
  {
    icon: '🏡',
    title: 'Scarce Land & Real Estate',
    description: 'Buy, rent, or develop plots. Land is limited. Expansion requires community funding.',
  },
  {
    icon: '🌲',
    title: 'Jobs & Skill Trees',
    description: 'Choose a profession — Miner, Farmer, Builder, Woodcutter, Hunter, or Fisher — and unlock perks as you level.',
  },
  {
    icon: '🏭',
    title: 'Player Shops',
    description: 'Open chest shops, set your own prices, and trade with other players. The market is yours.',
  },
  {
    icon: '⚖️',
    title: 'Laws & Punishments',
    description: 'In-game crimes get real consequences. Fines, jail time, plot eviction — handled by the law system.',
  },
  {
    icon: '📋',
    title: 'Public Contracts',
    description: 'Fund city development by completing public contracts. Resources leave the economy. Players get paid.',
  },
  {
    icon: '🗺️',
    title: 'Limited Borders',
    description: 'The world starts small. Expansion projects unlock new land when goals are met.',
  },
  {
    icon: '⚙️',
    title: 'Semi-Auto Production',
    description: 'Semi-automatic farms are allowed. AFK farms are not. Meaningful interaction is required.',
  },
];
---

<BaseLayout
  title="New Prosperity"
  description="A Minecraft survival economy server built around land, jobs, skill trees, public projects, and player-driven development."
>
  <Hero />

  <!-- What makes it different -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-20">
    <div class="text-center mb-12">
      <h2 class="font-heading text-2xl sm:text-3xl text-gold font-bold mb-3">What makes it different?</h2>
      <p class="text-cream/60 max-w-xl mx-auto">
        New Prosperity is built around scarcity, player agency, and genuine progression — not grinding the same loop forever.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {features.map(f => (
        <FeatureCard title={f.title} description={f.description} icon={f.icon} />
      ))}
    </div>
  </section>

  <!-- How progression works -->
  <section class="bg-slate-900 border-y border-slate-800 py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h2 class="font-heading text-2xl sm:text-3xl text-gold font-bold mb-6 text-center">How progression works</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-center">
        <div>
          <div class="text-3xl mb-3">👷</div>
          <h3 class="font-heading text-cream font-semibold mb-2">Start as a Worker</h3>
          <p class="text-cream/60 text-sm">Choose a starter job, earn your first money, and learn the market.</p>
        </div>
        <div>
          <div class="text-3xl mb-3">📈</div>
          <h3 class="font-heading text-cream font-semibold mb-2">Develop Your Profession</h3>
          <p class="text-cream/60 text-sm">Unlock skill tree abilities, vehicles, and equipment as you level up.</p>
        </div>
        <div>
          <div class="text-3xl mb-3">🌍</div>
          <h3 class="font-heading text-cream font-semibold mb-2">Shape the World</h3>
          <p class="text-cream/60 text-sm">Late-game players fund development projects that expand the server itself.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Season 0 warning + CTA -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-20">
    <div class="bg-slate-900 border border-slate-800 rounded-lg p-8">
      <InfoCallout type="warning" title="Under Construction">
        New Prosperity is currently under construction. Economy values, prices, job rewards, quest rewards, and progression requirements may change before launch.
      </InfoCallout>
      <InfoCallout type="info" title="In-Game First">
        This website is a reference guide. Required gameplay information is also available in-game through Town Hall, rules books, signs, and server menus.
      </InfoCallout>

      <div class="mt-8 text-center">
        <h2 class="font-heading text-xl text-gold mb-3">Ready to join?</h2>
        <p class="text-cream/60 mb-6 text-sm">Start with the Getting Started guide to learn the first 30 minutes.</p>
        <a
          href="/getting-started"
          class="inline-flex items-center justify-center px-8 py-3 rounded bg-emerald hover:bg-emerald-700 text-white font-medium transition-colors"
        >
          Getting Started Guide
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

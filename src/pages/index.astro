---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FeatureCard from '../components/FeatureCard.astro';

const features = [
  {
    icon: '🌲',
    title: 'Pick a Job, Earn Wages',
    description: 'Miner, Farmer, Builder, Woodcutter, Hunter, or Fisher. Each one pays per action and unlocks a skill tree as you level.',
  },
  {
    icon: '🏪',
    title: 'Real Player Market',
    description: 'The admin shop is a fallback. Tools, gear, food, and rare materials come from chest shops in the market district.',
  },
  {
    icon: '🏡',
    title: 'Land You Own',
    description: 'Rent an apartment cheap, save up for a plot, and build a base. Land is finite — first come, first served.',
  },
  {
    icon: '📋',
    title: 'Daily Contracts',
    description: 'The Contract Board at City Hall pays cash for raw materials. Easy money while you figure out your main grind.',
  },
];
---

<BaseLayout
  title="ProsperitySMP"
  description="A Minecraft survival economy server built around land, jobs, skill trees, public projects, and player-driven development."
>
  <Hero />

  <!-- What you do here -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-16">
    <div class="text-center mb-10">
      <h2 class="font-heading text-2xl sm:text-3xl text-gold font-bold mb-3">What you do here</h2>
      <p class="text-cream/60 max-w-xl mx-auto">
        A survival server built around player-driven economy — not grinding alone.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {features.map(f => (
        <FeatureCard title={f.title} description={f.description} icon={f.icon} />
      ))}
    </div>
  </section>

  <!-- First 10 minutes -->
  <section class="bg-slate-900 border-y border-slate-800 py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h2 class="font-heading text-2xl sm:text-3xl text-gold font-bold mb-2 text-center">Your first 10 minutes</h2>
      <p class="text-cream/60 text-center text-sm mb-10">After you connect, do these in order.</p>
      <ol class="space-y-4">
        <li class="flex gap-4">
          <span class="flex-shrink-0 w-8 h-8 rounded-full bg-emerald/20 border border-emerald/40 text-emerald font-bold flex items-center justify-center text-sm">1</span>
          <div>
            <h3 class="font-heading text-cream font-semibold mb-1">Pick a job</h3>
            <p class="text-cream/60 text-sm">Run <code class="text-gold font-mono text-xs bg-charcoal px-1.5 py-0.5 rounded">/jobs browse</code>, then <code class="text-gold font-mono text-xs bg-charcoal px-1.5 py-0.5 rounded">/jobs join &lt;name&gt;</code>. You get 3 free slots.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="flex-shrink-0 w-8 h-8 rounded-full bg-emerald/20 border border-emerald/40 text-emerald font-bold flex items-center justify-center text-sm">2</span>
          <div>
            <h3 class="font-heading text-cream font-semibold mb-1">Get to the resource world</h3>
            <p class="text-cream/60 text-sm">Type <code class="text-gold font-mono text-xs bg-charcoal px-1.5 py-0.5 rounded">/rtp</code> to teleport to a random spot in the mining area. Work your job there.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="flex-shrink-0 w-8 h-8 rounded-full bg-emerald/20 border border-emerald/40 text-emerald font-bold flex items-center justify-center text-sm">3</span>
          <div>
            <h3 class="font-heading text-cream font-semibold mb-1">Set a home</h3>
            <p class="text-cream/60 text-sm">When you find a good spot, <code class="text-gold font-mono text-xs bg-charcoal px-1.5 py-0.5 rounded">/sethome work</code>. Then <code class="text-gold font-mono text-xs bg-charcoal px-1.5 py-0.5 rounded">/home work</code> brings you back any time.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="flex-shrink-0 w-8 h-8 rounded-full bg-emerald/20 border border-emerald/40 text-emerald font-bold flex items-center justify-center text-sm">4</span>
          <div>
            <h3 class="font-heading text-cream font-semibold mb-1">Sell, save, plan</h3>
            <p class="text-cream/60 text-sm">Back at spawn, <code class="text-gold font-mono text-xs bg-charcoal px-1.5 py-0.5 rounded">/shop</code> for the admin store or use the market district for player shops. Check <code class="text-gold font-mono text-xs bg-charcoal px-1.5 py-0.5 rounded">/contracts</code> for daily cash.</p>
          </div>
        </li>
      </ol>
      <div class="text-center mt-10">
        <a href="/commands" class="inline-flex items-center gap-2 text-emerald hover:text-emerald/80 font-medium text-sm">
          See all commands →
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-16 text-center">
    <h2 class="font-heading text-2xl sm:text-3xl text-gold font-bold mb-3">Ready to join?</h2>
    <p class="text-cream/60 mb-8 text-sm">Cross-platform — Java and Bedrock share the same world.</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 max-w-xl mx-auto mb-8">
      <div class="bg-slate-900 border border-slate-800 rounded p-4 text-left">
        <div class="text-cream/40 text-xs uppercase tracking-wider mb-1">Java IP</div>
        <div class="text-gold font-mono text-sm break-all">play.prosperitysmp.com</div>
      </div>
      <div class="bg-slate-900 border border-slate-800 rounded p-4 text-left">
        <div class="text-cream/40 text-xs uppercase tracking-wider mb-1">Bedrock IP</div>
        <div class="text-gold font-mono text-sm break-all">15.204.249.228:19132</div>
      </div>
    </div>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href="/getting-started" class="inline-flex items-center justify-center px-6 py-3 rounded bg-emerald hover:bg-emerald-700 text-white font-medium transition-colors">
        Getting Started
      </a>
      <a href="/commands" class="inline-flex items-center justify-center px-6 py-3 rounded bg-slate-800 hover:bg-slate-700 text-cream font-medium border border-slate-700 transition-colors">
        Command Cheat Sheet
      </a>
    </div>
  </section>
</BaseLayout>

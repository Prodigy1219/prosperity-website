---
import { footerNav } from '../data/navigation';
import { serverInfo } from '../data/serverInfo';
---

<footer class="bg-charcoal border-t border-slate-800 mt-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <div class="flex items-center gap-3 mb-3">
          <img src="/logo.png" alt="New Prosperity" class="h-7 w-auto" />
          <span class="font-heading text-gold font-semibold">New Prosperity</span>
        </div>
        <p class="text-cream/50 text-sm">A survival economy Minecraft server built around land, jobs, skill trees, and player-driven development.</p>
      </div>
      <div>
        <h3 class="text-cream font-medium text-sm mb-3 uppercase tracking-wider">Navigation</h3>
        <ul class="space-y-2">
          {footerNav.map(link => (
            <li>
              <a href={link.href} class="text-cream/50 hover:text-gold text-sm transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="text-cream font-medium text-sm mb-3 uppercase tracking-wider">Server Info</h3>
        <ul class="space-y-2 text-sm">
          <li class="text-cream/50">Version: <span class="text-cream">{serverInfo.version}</span></li>
          <li class="text-cream/50">Status: <span class="text-gold">{serverInfo.status}</span></li>
          <li class="text-cream/50">Whitelist: <span class="text-cream">{serverInfo.whitelist}</span></li>
        </ul>
        <a
          href="https://discord.gg/wuKsJ7m6Fm"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-flex items-center gap-2 px-3 py-2 rounded bg-[#5865F2] hover:bg-[#4752c4] text-white text-sm font-medium transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.317 4.369A19.791 19.791 0 0 0 16.558 3a.075.075 0 0 0-.079.037c-.21.375-.444.864-.608 1.249a18.27 18.27 0 0 0-5.487 0 12.683 12.683 0 0 0-.617-1.249.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 5.93 4.369a.07.07 0 0 0-.032.027C2.533 9.046 1.605 13.58 2.06 18.057a.082.082 0 0 0 .031.056 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.105 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128c.126-.094.252-.192.371-.291a.074.074 0 0 1 .077-.01c3.927 1.793 8.18 1.793 12.061 0a.074.074 0 0 1 .078.01c.12.099.245.197.372.291a.077.077 0 0 1-.006.128 12.299 12.299 0 0 1-1.873.891.077.077 0 0 0-.041.106c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.84 19.84 0 0 0 6.002-3.03.077.077 0 0 0 .032-.055c.5-5.177-.838-9.674-3.548-13.66a.061.061 0 0 0-.031-.028zM8.02 15.331c-1.182 0-2.157-1.086-2.157-2.419 0-1.333.956-2.418 2.157-2.418 1.21 0 2.176 1.094 2.157 2.418 0 1.333-.956 2.419-2.157 2.419zm7.974 0c-1.182 0-2.156-1.086-2.156-2.419 0-1.333.955-2.418 2.156-2.418 1.21 0 2.177 1.094 2.157 2.418 0 1.333-.946 2.419-2.157 2.419z"/>
          </svg>
          Join the Discord
        </a>
      </div>
    </div>
    <div class="mt-8 pt-6 border-t border-slate-800 text-center text-cream/30 text-xs">
      &copy; {new Date().getFullYear()} New Prosperity. All rights reserved.
    </div>
  </div>
</footer>

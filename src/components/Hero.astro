---
---

<section class="relative overflow-hidden bg-charcoal pt-20 pb-24">
  <!-- Background grid pattern -->
  <div class="absolute inset-0 opacity-5" style="background-image: linear-gradient(#0f8f4f 1px, transparent 1px), linear-gradient(90deg, #0f8f4f 1px, transparent 1px); background-size: 40px 40px;"></div>

  <!-- Glow effect -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-96 rounded-full opacity-10" style="background: radial-gradient(circle, #0f8f4f 0%, transparent 70%);"></div>

  <div class="relative max-w-5xl mx-auto px-4 sm:px-6 text-center">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-dark/50 border border-emerald/30 text-emerald text-xs font-medium mb-8">
      <span class="w-1.5 h-1.5 rounded-full bg-emerald animate-pulse"></span>
      Season 0 / Beta — Now Testing
    </div>

    <h1 class="font-heading text-5xl sm:text-6xl lg:text-7xl font-bold text-cream mb-4 leading-tight">
      New Prosperity
    </h1>

    <p class="font-heading text-xl sm:text-2xl text-gold mb-6">
      Build wealth. Shape the frontier.
    </p>

    <p class="text-cream/70 text-lg max-w-2xl mx-auto mb-10 leading-relaxed">
      A survival economy Minecraft server where players earn, trade, buy land, specialize through skill trees, run companies, and fund the expansion of the world itself.
    </p>

    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a
        href="/getting-started"
        class="inline-flex items-center justify-center px-6 py-3 rounded bg-emerald hover:bg-emerald-700 text-white font-medium transition-colors"
      >
        Get Started
      </a>
      <a
        href="/rules"
        class="inline-flex items-center justify-center px-6 py-3 rounded bg-slate-800 hover:bg-slate-700 text-cream font-medium border border-slate-700 transition-colors"
      >
        Read the Rules
      </a>
    </div>

    <!-- Server info bar -->
    <div class="mt-12 inline-grid grid-cols-2 sm:grid-cols-3 gap-x-8 gap-y-3 text-sm text-left mx-auto">
      <div>
        <span class="text-cream/40 block text-xs uppercase tracking-wider">Server IP</span>
        <span class="text-cream font-mono">Coming Soon</span>
      </div>
      <div>
        <span class="text-cream/40 block text-xs uppercase tracking-wider">Version</span>
        <span class="text-cream font-mono">Paper 1.21.1</span>
      </div>
      <div class="col-span-2 sm:col-span-1">
        <span class="text-cream/40 block text-xs uppercase tracking-wider">Status</span>
        <span class="text-gold font-medium">Season 0 / Beta</span>
      </div>
    </div>
  </div>
</section>

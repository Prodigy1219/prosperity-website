---
---

<section class="relative overflow-hidden bg-charcoal pt-20 pb-24">
  <!-- Background grid pattern -->
  <div class="absolute inset-0 opacity-5" style="background-image: linear-gradient(#0f8f4f 1px, transparent 1px), linear-gradient(90deg, #0f8f4f 1px, transparent 1px); background-size: 40px 40px;"></div>

  <!-- Glow effect -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-96 rounded-full opacity-10" style="background: radial-gradient(circle, #0f8f4f 0%, transparent 70%);"></div>

  <div class="relative max-w-5xl mx-auto px-4 sm:px-6 text-center">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald/10 border border-emerald/40 text-emerald text-xs font-medium mb-8">
      <span class="w-1.5 h-1.5 rounded-full bg-emerald animate-pulse"></span>
      LIVE NOW — Season 0 Open
    </div>

    <h1 class="font-heading text-5xl sm:text-6xl lg:text-7xl font-bold text-cream mb-4 leading-tight">
      ProsperitySMP
    </h1>

    <p class="font-heading text-xl sm:text-2xl text-gold mb-6">
      Build wealth. Shape the frontier.
    </p>

    <p class="text-cream/70 text-lg max-w-2xl mx-auto mb-10 leading-relaxed">
      A survival economy Minecraft server where players earn, trade, buy land, specialize through skill trees, run companies, and fund the expansion of the world itself.
    </p>

    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a
        href="/getting-started"
        class="inline-flex items-center justify-center px-6 py-3 rounded bg-emerald hover:bg-emerald-700 text-white font-medium transition-colors"
      >
        Get Started
      </a>
      <a
        href="https://discord.gg/wuKsJ7m6Fm"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded bg-[#5865F2] hover:bg-[#4752c4] text-white font-medium transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.317 4.369A19.791 19.791 0 0 0 16.558 3a.075.075 0 0 0-.079.037c-.21.375-.444.864-.608 1.249a18.27 18.27 0 0 0-5.487 0 12.683 12.683 0 0 0-.617-1.249.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 5.93 4.369a.07.07 0 0 0-.032.027C2.533 9.046 1.605 13.58 2.06 18.057a.082.082 0 0 0 .031.056 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.105 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128c.126-.094.252-.192.371-.291a.074.074 0 0 1 .077-.01c3.927 1.793 8.18 1.793 12.061 0a.074.074 0 0 1 .078.01c.12.099.245.197.372.291a.077.077 0 0 1-.006.128 12.299 12.299 0 0 1-1.873.891.077.077 0 0 0-.041.106c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.84 19.84 0 0 0 6.002-3.03.077.077 0 0 0 .032-.055c.5-5.177-.838-9.674-3.548-13.66a.061.061 0 0 0-.031-.028zM8.02 15.331c-1.182 0-2.157-1.086-2.157-2.419 0-1.333.956-2.418 2.157-2.418 1.21 0 2.176 1.094 2.157 2.418 0 1.333-.956 2.419-2.157 2.419zm7.974 0c-1.182 0-2.156-1.086-2.156-2.419 0-1.333.955-2.418 2.156-2.418 1.21 0 2.177 1.094 2.157 2.418 0 1.333-.946 2.419-2.157 2.419z"/>
        </svg>
        Join the Discord
      </a>
      <a
        href="/rules"
        class="inline-flex items-center justify-center px-6 py-3 rounded bg-slate-800 hover:bg-slate-700 text-cream font-medium border border-slate-700 transition-colors"
      >
        Read the Rules
      </a>
    </div>

    <!-- Server info bar -->
    <div class="mt-12 inline-grid grid-cols-1 sm:grid-cols-3 gap-x-8 gap-y-3 text-sm text-left mx-auto">
      <div>
        <span class="text-cream/40 block text-xs uppercase tracking-wider">Java IP</span>
        <span class="text-gold font-mono">play.prosperitysmp.com</span>
      </div>
      <div>
        <span class="text-cream/40 block text-xs uppercase tracking-wider">Bedrock IP</span>
        <span class="text-gold font-mono">15.204.249.228:19132</span>
      </div>
      <div>
        <span class="text-cream/40 block text-xs uppercase tracking-wider">Version</span>
        <span class="text-cream font-mono">Paper 1.21.8</span>
      </div>
    </div>
  </div>
</section>
